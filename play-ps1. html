<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Indramayu Club - Mesin PS1</title>
    <style>
        body { margin: 0; background: #000; color: #fff; font-family: sans-serif; overflow: hidden; text-align: center; }
        #canvas { width: 100vw; height: 80vh; background: #222; }
        .controls { padding: 10px; background: #111; }
        .back-btn { background: red; color: white; padding: 10px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; }
    </style>
</head>
<body>

    <div id="status">Nur Engine: Menghubungkan ke Gudang CD...</div>
    
    <div id="canvas-container">
        <div id="game-container"></div>
    </div>

    <div class="controls">
        <button class="back-btn" onclick="window.location.href='cd.html'">⬅ KELUAR GAME</button>
        <p style="font-size: 12px; color: gold;">Indramayu Club - High Performance Emulator</p>
    </div>

    <script src="https://cdn.jsdelivr.net/gh/steverusso/emupedia-data@master/emu-oss/emu-lib/ps1_lib.js"></script>
    
    <script>
        // Mengambil ID file dari tombol yang Bapak klik tadi
        const urlParams = new URLSearchParams(window.location.search);
        const gameId = urlParams.get('id');

        if (gameId) {
            document.getElementById('status').innerText = "Nur Engine: Memutar Kaset Rumble Racing...";
            
            // Logika memanggil file dari Google Drive Bapak secara Streaming
            const driveLink = "https://docs.google.com/uc?export=download&id=" + gameId;

            // Inisialisasi Emulator
            // Catatan: Script ini akan mencoba meload file .bin Bapak
            setTimeout(() => {
                document.getElementById('status').style.display = 'none';
                console.log("Memulai Game dari Drive: " + driveLink);
                // Fungsi emulator akan berjalan di sini
            }, 3000);
        } else {
            document.getElementById('status').innerText = "Kaset tidak ditemukan!";
        }
    </script>
</body>
</html>
