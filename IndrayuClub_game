<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Indramayu Club Game</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap');
        body { background: #020617; color: white; font-family: 'Orbitron', sans-serif; overflow: hidden; }
        
        /* Efek Glow Monitor */
        .monitor-glow {
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.4), inset 0 0 10px rgba(6, 182, 212, 0.2);
            border: 2px solid #0891b2;
        }

        /* Animasi Tombol Nur */
        .btn-nur {
            background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-nur:active { transform: scale(0.95); filter: brightness(1.2); }

        .kaset-card {
            transition: transform 0.3s;
            border: 1px solid #1e293b;
        }
        .kaset-card:active { transform: translateY(-5px); border-color: #eab308; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="p-5 bg-slate-950 min-h-screen">

    <header class="mb-6">
        <div class="flex justify-between items-center">
            <div>
                <h1 class="text-cyan-400 text-lg font-bold tracking-tighter">INDRAMAYU CLUB</h1>
                <p class="text-[9px] text-slate-500 tracking-[0.3em]">GAME CONSOLE V.2</p>
            </div>
            <div class="text-right">
                <p class="text-[8px] text-yellow-500 uppercase">Token Cash</p>
                <h2 id="balance" class="text-xs font-bold text-white">Rp 0</h2>
            </div>
        </div>
    </header>

    <main class="monitor-glow bg-black rounded-3xl p-4 mb-6 relative overflow-hidden h-44 flex flex-col items-center justify-center">
        <div id="game-preview" class="absolute inset-0 opacity-30 grayscale blur-[2px]">
            <img id="bg-poster" src="" class="w-full h-full object-cover hidden">
        </div>
        
        <div class="z-10 text-center">
            <h2 id="active-title" class="text-sm font-bold tracking-widest text-white uppercase">Insert Disc</h2>
            <div class="flex gap-2 mt-2 justify-center">
                <span class="w-1.5 h-1.5 bg-cyan-500 rounded-full animate-ping"></span>
                <span id="status-msg" class="text-[8px] text-cyan-300 uppercase tracking-widest">Nur Engine Ready</span>
            </div>
        </div>
    </main>
<section>
<section class="px-2 mb-6">
    <button onclick="window.location.href='cd.html'" class="w-full flex items-center justify-between bg-slate-900 border border-cyan-500/30 p-4 rounded-2xl shadow-lg active:scale-95 transition-all">
        <div class="flex items-center gap-3">
            <span class="text-xl">💿</span>
            <div class="text-left">
                <h3 class="text-[10px] font-bold text-white uppercase tracking-widest">Buka Gudang CD</h3>
                <p class="text-[7px] text-cyan-400 uppercase">Indramayu Club Secret Storage</p>
            </div>
        </div>
        <span class="text-[10px] text-slate-500">ENTER →</span>
    </button>
</section>


    

            <button onclick="pilih('RUMBLE RACING', 'https://m.media-amazon.com/images/I/51G8K280TCL.jpg')" class="kaset-card shrink-0 w-28 bg-slate-900 rounded-xl overflow-hidden">
                <img src="https://m.media-amazon.com/images/I/51G8K280TCL.jpg" class="h-32 w-full object-cover">
                <p class="text-[7px] p-2 text-center text-slate-300 uppercase">Rumble Racing</p>
            </button>

            <button onclick="pilih('SPIDERMAN 2', 'https://vimm.net/vault/images/covers/ps1/Spider-Man.jpg')" class="kaset-card shrink-0 w-28 bg-slate-900 rounded-xl overflow-hidden">
                <img src="https://vimm.net/vault/images/covers/ps1/Spider-Man.jpg" class="h-32 w-full object-cover">
                <p class="text-[7px] p-2 text-center text-slate-300 uppercase">Spiderman 2</p>
            </button>

            <button class="kaset-card shrink-0 w-28 bg-slate-900/50 border-dashed border border-slate-700 rounded-xl flex items-center justify-center">
                <span class="text-[20px] text-slate-700">+</span>
            </button>
        </div>
    </section>

    <footer class="fixed bottom-0 left-0 w-full p-5 bg-slate-950/90 backdrop-blur-md border-t border-slate-800">
        <div class="mb-4">
            <input type="text" id="v-code" placeholder="ENTER VOUCHER: INDRAMAYUCLUB" class="w-full bg-slate-900 border border-slate-800 rounded-xl p-3 text-center text-[10px] text-yellow-500 font-bold uppercase tracking-widest outline-none focus:border-cyan-500 transition-all">
        </div>
        <button onclick="konfirmasi()" class="btn-nur w-full py-4 rounded-2xl text-[10px] font-bold tracking-[0.3em] shadow-lg shadow-cyan-900/20 uppercase">
            Aktivasi Mesin Nur
        </button>
    </footer>

    <script>
        let selected = "";

        function pilih(game, img) {
            if (navigator.vibrate) navigator.vibrate(50);
            selected = game;
            document.getElementById('active-title').innerText = game;
            document.getElementById('bg-poster').src = img;
            document.getElementById('bg-poster').classList.remove('hidden');
            document.getElementById('status-msg').innerText = "DISC READY";
        }

        function konfirmasi() {
            const code = document.getElementById('v-code').value.toUpperCase();
            if(!selected) return alert("Pilih Kasetnya Dulu, Pak!");
            
            if(code === "INDRAMAYUCLUB") {
                // Nur mencatat ke Google Drive (Ruh Baru)
                const NUR_URL = "https://script.google.com/macros/s/AKfycbwBi5rv3pd8tANS63Ig3VZF34FSvt1Br_jx79kl66xpr8tzaTtAlFh-Nnrthk3lTWtM/exec";
                fetch(`${NUR_URL}?action=mainGame&game=${selected}&voucher=${code}`, {mode: 'no-cors'});
                
                alert("BERHASIL! Nur telah membuka akses.");
                window.location.href = `https://wa.me/6281386517352?text=NUR+ENGINE+AKTIF:+${selected}+Voucher+${code}`;
            } else {
                alert("KODE VOUCHER SALAH!");
            }
        }
    </script>
</body>
</html>
